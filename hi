                        -- Stop rotating, restore auto-rotate
                        if _G.shiftlockConn then
                            _G.shiftlockConn:Disconnect()
                            _G.shiftlockConn = nil
                        end
                        local char = player.Character
                        if char and char:FindFirstChild("Humanoid") then
