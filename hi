        action = function(args)
            local name = args and args[1]
            if not name then return end
            local speed    = tonumber(args[2]) or 0.2
            local distance = tonumber(args[3]) or 6
            _G.orbitOn = true
            local rot = 0
            if _G.orbitConn then _G.orbitConn:Disconnect() end
            if _G.orbitFaceConn then _G.orbitFaceConn:Disconnect() end
            _G.orbitConn = RunService.Heartbeat:Connect(function(dt)
                if not _G.orbitOn then _G.orbitConn:Disconnect(); return end
                local target = nil
                for _, p in pairs(Players:GetPlayers()) do
