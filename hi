        for _, eb in ipairs(_G.eventBinds) do
            if eb.event == evName then
                local found = false
                for _, cmd in ipairs(COMMANDS) do
                    local isMatch = cmd.name == eb.cmd
                    if not isMatch and cmd.alias then
                        for _, a in ipairs(cmd.alias) do if a == eb.cmd then isMatch = true break end end
                    end
                    if isMatch then pcall(cmd.action, {}); found = true; break end
                end
            end
        end
    end
