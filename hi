local function closeTogglesPanel()
    if togglesPanel and togglesPanel.Parent then
        togglesPanel:Destroy()
        togglesPanel = nil
    end
    togglesPanelOpen = false
end

local function openTogglesPanel()
    if togglesPanel and togglesPanel.Parent then return end
    togglesPanelOpen = true

    -- ── layout constants (all pixel-based, no scale) ──
    local PW       = 260   -- panel width in pixels
    local HEADER_H = 18    -- section header height
    local ROW_H    = 26    -- single toggle or textbox row height
    local COMBO_H  = 48    -- paired toggle+textbox combined row height
    local MAX_VIS  = 280   -- max visible height before scroll

    -- pre-calculate canvas height
    local canvasH = 0
    local idx2 = 1
    while idx2 <= #TOGGLES do
        local it = TOGGLES[idx2]
        if it.type == "header" then
            canvasH = canvasH + HEADER_H
            idx2 = idx2 + 1
        elseif it.type == "toggle" then
            local nxt = TOGGLES[idx2 + 1]
            if nxt and nxt.type == "textbox" then
                canvasH = canvasH + COMBO_H
                idx2 = idx2 + 2
            else
                canvasH = canvasH + ROW_H
                idx2 = idx2 + 1
            end
        else
            canvasH = canvasH + ROW_H
            idx2 = idx2 + 1
        end
    end

    local visH   = math.min(canvasH, MAX_VIS)
    local panelY = INPUT_Y + INPUT_H

    -- ── outer panel (fixed width, clipping) ──
    togglesPanel = Instance.new("Frame")
    togglesPanel.Name                   = "TogglesPanel"
    togglesPanel.Size                   = UDim2.new(0, PW, 0, visH)
    togglesPanel.Position               = UDim2.new(0, 0, 0, panelY)
    togglesPanel.BackgroundColor3       = Color3.fromRGB(28, 28, 28)
    togglesPanel.BackgroundTransparency = 0
    togglesPanel.BorderSizePixel        = 0
    togglesPanel.ClipsDescendants       = true
    togglesPanel.ZIndex                 = 15
    togglesPanel.Parent                 = screenGui

    -- ── scrolling frame ──
    local scrollF = Instance.new("ScrollingFrame")
    scrollF.Size                  = UDim2.new(1, 0, 1, 0)
    scrollF.BackgroundTransparency = 1
    scrollF.BorderSizePixel       = 0
    scrollF.ScrollBarThickness    = canvasH > visH and 3 or 0
    scrollF.ScrollBarImageColor3  = Color3.fromRGB(255, 196, 0)
    scrollF.CanvasSize            = UDim2.new(0, 0, 0, canvasH)
    scrollF.ScrollingDirection    = Enum.ScrollingDirection.Y
    scrollF.ElasticBehavior       = Enum.ElasticBehavior.Never
    scrollF.ZIndex                = 15
    scrollF.Parent                = togglesPanel

    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding   = UDim.new(0, 0)
    listLayout.Parent    = scrollF

    -- ── colours ──
    local BG_A = Color3.fromRGB(44, 44, 44)
    local BG_B = Color3.fromRGB(52, 52, 52)
    local YELLOW = Color3.fromRGB(255, 196, 0)
    local OFF    = Color3.fromRGB(65, 65, 65)
    local TBGBG  = Color3.fromRGB(30, 30, 30)

    -- ── pixel positions inside a row ──
    -- label starts at x=8, switch starts right after label text
    -- we keep label to 140px wide, switch at x=150
    local LBL_W   = 142  -- label width
    local SW_X    = 152  -- switch left edge (pixels from row left)
    local SW_W    = 36   -- switch width
    local SW_H    = 18   -- switch height
    local TB_X    = 150  -- textbox left edge
    local TB_W    = 96   -- textbox width

    local colorCycle = 0
    local function nextBg()
        colorCycle = colorCycle + 1
        return colorCycle % 2 == 0 and BG_B or BG_A
    end

    -- ── row builders ──
    local function makeRow(h, bg, order)
        local f = Instance.new("Frame")
        f.Size             = UDim2.new(0, PW, 0, h)
        f.BackgroundColor3 = bg
        f.BorderSizePixel  = 0
        f.LayoutOrder      = order
        f.ZIndex           = 15
        f.Parent           = scrollF
        return f
    end

    local function makeLabel(parent, txt, y, h, color, size)
        local l = Instance.new("TextLabel")
        l.Size                 = UDim2.new(0, LBL_W, 0, h)
        l.Position             = UDim2.new(0, 8, 0, y)
        l.BackgroundTransparency = 1
        l.Text                 = txt
        l.TextColor3           = color or Color3.fromRGB(210, 210, 210)
        l.Font                 = Enum.Font.Code
        l.TextSize             = size or 13
        l.TextXAlignment       = Enum.TextXAlignment.Left
        l.TextTruncate         = Enum.TextTruncate.AtEnd
        l.ZIndex               = 16
        l.Parent               = parent
        return l
    end

    local function makeSwitch(parent, item, y)
        local swBg = Instance.new("TextButton")
        swBg.Size             = UDim2.new(0, SW_W, 0, SW_H)
        swBg.Position         = UDim2.new(0, SW_X, 0, y)
        swBg.BackgroundColor3 = item.enabled and YELLOW or OFF
        swBg.Text             = ""
        swBg.BorderSizePixel  = 0
        swBg.ZIndex           = 16
        swBg.Parent           = parent
        Instance.new("UICorner", swBg).CornerRadius = UDim.new(1, 0)

        local kW = SW_H - 4
        local knob = Instance.new("Frame")
        knob.Size             = UDim2.new(0, kW, 0, kW)
        knob.Position         = item.enabled
            and UDim2.new(0, SW_W - kW - 2, 0.5, -kW/2)
            or  UDim2.new(0, 2,              0.5, -kW/2)
        knob.BackgroundColor3 = Color3.new(1, 1, 1)
        knob.BorderSizePixel  = 0
        knob.ZIndex           = 17
        knob.Parent           = swBg
        Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

        swBg.MouseButton1Click:Connect(function()
            item.enabled = not item.enabled
            swBg.BackgroundColor3 = item.enabled and YELLOW or OFF
            knob.Position = item.enabled
                and UDim2.new(0, SW_W - kW - 2, 0.5, -kW/2)
                or  UDim2.new(0, 2,              0.5, -kW/2)
            if item.enabled     and item.onEnable  then item.onEnable()  end
            if not item.enabled and item.onDisable then item.onDisable() end
        end)
        return swBg
    end

    local function makeTextbox(parent, tbItem, y)
        local tb = Instance.new("TextBox")
        tb.Size             = UDim2.new(0, TB_W, 0, SW_H)
        tb.Position         = UDim2.new(0, TB_X, 0, y)
        tb.BackgroundColor3 = TBGBG
        tb.Text             = tbItem.value or ""
        tb.PlaceholderText  = tbItem.placeholder or ""
        tb.PlaceholderColor3 = Color3.fromRGB(80, 80, 80)
        tb.TextColor3       = Color3.fromRGB(220, 220, 220)
        tb.Font             = Enum.Font.Code
        tb.TextSize         = 12
        tb.BorderSizePixel  = 0
        tb.ClearTextOnFocus = false
        tb.ZIndex           = 16
        tb.Parent           = parent
        Instance.new("UICorner", tb).CornerRadius = UDim.new(0, 3)
        tb:GetPropertyChangedSignal("Text"):Connect(function()
            tbItem.value = tb.Text
        end)
        return tb
    end

    -- ── iterate and build rows ──
    local order = 0
    local i = 1
    while i <= #TOGGLES do
        local item = TOGGLES[i]
        order = order + 1

        if item.type == "header" then
            -- section header
            local hrow = Instance.new("Frame")
            hrow.Size             = UDim2.new(0, PW, 0, HEADER_H)
            hrow.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
            hrow.BorderSizePixel  = 0
            hrow.LayoutOrder      = order
            hrow.ZIndex           = 15
            hrow.Parent           = scrollF
            local hl = Instance.new("TextLabel")
            hl.Size                 = UDim2.new(1, -8, 1, 0)
            hl.Position             = UDim2.new(0, 8, 0, 0)
            hl.BackgroundTransparency = 1
            hl.Text                 = item.name
            hl.TextColor3           = YELLOW
            hl.Font                 = Enum.Font.GothamBold
            hl.TextSize             = 10
            hl.TextXAlignment       = Enum.TextXAlignment.Left
            hl.ZIndex               = 16
            hl.Parent               = hrow
            i = i + 1

        elseif item.type == "toggle" then
            local nxt    = TOGGLES[i + 1]
            local hasPair = nxt and nxt.type == "textbox"
            local bg      = nextBg()

            if hasPair then
                -- COMBO: toggle row + textbox row merged, switch RIGHT after label
                local midY   = math.floor((COMBO_H - ROW_H) / 2)
                local row    = makeRow(COMBO_H, bg, order)

                -- toggle label + switch (top half, centred vertically in ROW_H)
                local swY = math.floor((ROW_H - SW_H) / 2)
                makeLabel(row, item.name,
                    swY + math.floor(SW_H/2) - 7, SW_H,
                    Color3.fromRGB(210, 210, 210), 12)
                makeSwitch(row, item, swY)

                -- thin divider
                local div = Instance.new("Frame")
                div.Size             = UDim2.new(1, -8, 0, 1)
                div.Position         = UDim2.new(0, 4, 0, ROW_H)
                div.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                div.BorderSizePixel  = 0
                div.ZIndex           = 16
                div.Parent           = row

                -- textbox label + box (bottom half)
                local tbY = ROW_H + math.floor((COMBO_H - ROW_H - SW_H) / 2)
                makeLabel(row, nxt.name, tbY, SW_H,
                    Color3.fromRGB(155, 155, 155), 11)
                makeTextbox(row, nxt, tbY)

                i = i + 2
            else
                -- STANDALONE toggle
                local row = makeRow(ROW_H, bg, order)
                local swY = math.floor((ROW_H - SW_H) / 2)
                makeLabel(row, item.name,
                    swY + math.floor(SW_H/2) - 7, SW_H,
                    Color3.fromRGB(210, 210, 210), 12)
                makeSwitch(row, item, swY)
                i = i + 1
            end

        elseif item.type == "textbox" then
            -- STANDALONE textbox
            local bg  = nextBg()
            local row = makeRow(ROW_H, bg, order)
            local tbY = math.floor((ROW_H - SW_H) / 2)
            makeLabel(row, item.name, tbY, SW_H,
                Color3.fromRGB(200, 200, 200), 12)
            makeTextbox(row, item, tbY)
            i = i + 1
        else
            i = i + 1
        end
    end
end

togglesBtn.MouseButton1Click:Connect(function()
