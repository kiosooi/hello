RunService.Heartbeat:Connect(function()
    if not TOGGLES then return end

    -- loop speed
    local lsT = getToggle("loop speed")
    if lsT and lsT.enabled and speedTB then
        local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        local s = tonumber(speedTB.value); if h and s then h.WalkSpeed = s end end

    -- loop jumppower
    local ljT = getToggle("loop jumppower")
    if ljT and ljT.enabled and jumpTB then
        local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        local j = tonumber(jumpTB.value)
        if h and j then
            if h.UseJumpPower then h.JumpPower = j else h.JumpHeight = j end
        end end

    -- loop hipheight
    local lhT = getToggle("loop hipheight")
    if lhT and lhT.enabled and hipTB then
        local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        local v = tonumber(hipTB.value); if h and v then h.HipHeight = v end end

    -- loop health
    local lhpT = getToggle("loop health")
    if lhpT and lhpT.enabled and healthTB then
        local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        local v = tonumber(healthTB.value)
        if h and v and h.Health < v then h.Health = v end end

    -- loop gravity
    local lgT = getToggle("loop gravity")
    if lgT and lgT.enabled and gravTB then
        local v = tonumber(gravTB.value); if v then workspace.Gravity = v end end

    -- loop noclip
    local ncT = getToggle("loop noclip")
    if ncT and ncT.enabled then
        local c = player.Character
        if c then for _, v in pairs(c:GetDescendants()) do
            if v:IsA("BasePart") and v.CanCollide then v.CanCollide = false end
        end end end

    -- loop xray
    local xrT = getToggle("loop xray")
    if xrT and xrT.enabled then
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v.Parent:FindFirstChildOfClass("Humanoid") then
                v.LocalTransparencyModifier = 0.6 end
        end end

    -- loop invisible
    local liT = getToggle("loop invisible")
    if liT and liT.enabled then
        local c = player.Character
        if c then for _, v in pairs(c:GetDescendants()) do
            if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                v.LocalTransparencyModifier = 1 end
        end end end

    -- loop fullbright
    local fbT = getToggle("loop fullbright")
    if fbT and fbT.enabled then
        Lighting.Brightness=2; Lighting.ClockTime=14
        Lighting.FogEnd=100000; Lighting.GlobalShadows=false
        Lighting.OutdoorAmbient=Color3.fromRGB(128,128,128) end

    -- loop nofog
    local nfT = getToggle("loop nofog")
    if nfT and nfT.enabled then
        Lighting.FogEnd=100000; Lighting.FogStart=0 end

    -- loop fov
    local lfT = getToggle("loop fov")
    if lfT and lfT.enabled and fovTB then
        local v = tonumber(fovTB.value)
        if v then workspace.CurrentCamera.FieldOfView = v end end

    -- loop spin
    local lspT = getToggle("loop spin")
    if lspT and lspT.enabled and spinTB then
        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        local spd  = tonumber(spinTB.value) or 20
        if root then
            local bav = root:FindFirstChild("__spin")
            if bav and bav:IsA("BodyAngularVelocity") then
                bav.AngularVelocity = Vector3.new(0, spd, 0) end
        end end

    -- loop animspeed
    local laT = getToggle("loop animspeed")
    if laT and laT.enabled and animSpeedTB then
        local spd = tonumber(animSpeedTB.value)
        if spd then
            local h = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
            if h then for _, t in ipairs(h:GetPlayingAnimationTracks()) do t:AdjustSpeed(spd) end end
        end end

    -- fly/vfly/tween speed textboxes
    if flyspeedTB  then local s = tonumber(flyspeedTB.value);   if s then _G.iyflyspeed  = s end end
    if vflyspeedTB then local s = tonumber(vflyspeedTB.value);  if s then _G.iyvflyspeed = s end end
    if tweenSpeedTB then local s = tonumber(tweenSpeedTB.value); if s then _G.tweenSpeed  = s end end
end)

