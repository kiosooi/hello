                    if not _G.shiftlockEnabled then return end
                    if input.KeyCode ~= Enum.KeyCode.LeftControl then return end

                    _G.shiftlockActive = not _G.shiftlockActive

                    if _G.shiftlockActive then
                        -- Start rotating character to match camera yaw every frame
                        if _G.shiftlockConn then _G.shiftlockConn:Disconnect() end
                        _G.shiftlockConn = RunService.RenderStepped:Connect(function()
