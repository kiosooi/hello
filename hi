    -- Build all row frames, stored so search can show/hide
    local allRows = {}

    local function buildRows(filterText)
        -- Clear existing rows
        for _, v in pairs(scrollFrame:GetChildren()) do
            if v:IsA("Frame") then v:Destroy() end
        end
        allRows = {}

        local order = 0
        for _, cmd in ipairs(COMMANDS) do
            local query = (filterText or ""):lower()
            local nameMatch = cmd.name:lower():find(query, 1, true)
            local descMatch = cmd.desc:lower():find(query, 1, true)
            local aliasMatch = false
            if not nameMatch and cmd.alias then
                for _, a in ipairs(cmd.alias) do
                    if a:lower():find(query, 1, true) then aliasMatch = true; break end
                end
            end
            if query == "" or nameMatch or descMatch or aliasMatch then
                order = order + 1
                local row = Instance.new("Frame")
                row.Size             = UDim2.new(1, -8, 0, ROW_H2)
                row.BackgroundColor3 = Color3.fromRGB(52, 52, 52)
                row.BorderSizePixel  = 0
                row.LayoutOrder      = order
                row.ZIndex           = 22
                row.Parent           = scrollFrame
                Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)

                local accent = Instance.new("Frame")
                accent.Size             = UDim2.new(0, 4, 1, 0)
                accent.BackgroundColor3 = Color3.fromRGB(255, 196, 0)
                accent.BorderSizePixel  = 0
                accent.ZIndex           = 23
                accent.Parent           = row
                Instance.new("UICorner", accent).CornerRadius = UDim.new(0, 4)

                local cName = Instance.new("TextLabel")
                cName.Size              = UDim2.new(1, -18, 0, 22)
                cName.Position          = UDim2.new(0, 14, 0, 8)
                cName.BackgroundTransparency = 1
                local aliasStr = ""
                if cmd.alias and #cmd.alias > 0 then
                    aliasStr = "  |  ;" .. table.concat(cmd.alias, "  ;")
                end
                cName.Text = ";" .. cmd.name .. (cmd.args and (" " .. cmd.args) or "") .. aliasStr
                cName.TextColor3        = Color3.fromRGB(255, 196, 0)
                cName.Font              = Enum.Font.GothamBold
                cName.TextSize          = 14
                cName.TextXAlignment    = Enum.TextXAlignment.Left
                cName.ZIndex            = 23
                cName.Parent            = row

                local cDesc = Instance.new("TextLabel")
                cDesc.Size              = UDim2.new(1, -18, 0, 26)
                cDesc.Position          = UDim2.new(0, 14, 0, 28)
                cDesc.BackgroundTransparency = 1
                cDesc.Text              = cmd.desc
                cDesc.TextColor3        = Color3.fromRGB(175, 175, 175)
                cDesc.Font              = Enum.Font.Gotham
                cDesc.TextSize          = 12
                cDesc.TextXAlignment    = Enum.TextXAlignment.Left
                cDesc.TextWrapped       = true
                cDesc.ZIndex            = 23
                cDesc.Parent            = row

                table.insert(allRows, row)
            end
        end

        -- Update canvas height
        local totalH = order * ROW_H2 + math.max(0, order - 1) * ROW_PAD
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, totalH)
    end

    buildRows("")

    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        buildRows(searchBox.Text)
    end)
end

