                if not head.Parent then _G.cflyConn:Disconnect(); return end
                local moveDir = char:FindFirstChildOfClass("Humanoid").MoveDirection
                local cam     = workspace.CurrentCamera
                local offset  = CFrame.new(moveDir * _G.cflyspeed * dt)
                -- project movement onto camera facing
                local fwd  = cam.CFrame.LookVector
                local right= cam.CFrame.RightVector
                local mv = (right * moveDir.X + fwd * -moveDir.Z) * _G.cflyspeed * dt
                head.CFrame = head.CFrame + mv
            end)
        end,
