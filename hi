--  CHAT DETECTION
-- ══════════════════════════════════════════
local function isChatFocused()
    local focused = UserInputService:GetFocusedTextBox()
    if not focused then return false end
    local obj = focused
    while obj do
        local n = obj.Name:lower()
        if n:find("chat") or n == "topbarapp" then return true end
        obj = obj.Parent
    end
    return false
end

