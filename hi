--  OPEN / CLOSE BAR
-- ══════════════════════════════════════════
local panelWasOpen = false

local function closeBar()
    barOpen = false
    panelWasOpen = togglesPanelOpen
    clearSuggestions()
    topBar.Visible     = false
    inputFrame.Visible = false
    cmdInput.Text      = ""
    cmdInput:ReleaseFocus()
    closeTogglesPanel()
end

local function openBar()
    barOpen          = true
    openedAt         = tick()
    topBar.Visible   = true
    inputFrame.Visible = true
    cmdInput.Text    = ";"
    if panelWasOpen then
        openTogglesPanel()
    end
    task.defer(function()
        cmdInput:CaptureFocus()
        cmdInput.CursorPosition = 2
    end)
end

-- ══════════════════════════════════════════
--  ENTER → RUN COMMAND
-- ══════════════════════════════════════════
cmdInput.FocusLost:Connect(function(enterPressed)
    if not enterPressed then
        task.defer(function()
            local focused = UserInputService:GetFocusedTextBox()
            if focused ~= nil and focused ~= cmdInput then return end
        end)
        return
    end

    local text = cmdInput.Text
    if text:sub(1,1) ~= ";" then return end
    -- Parse: ";gravity 55" → name="gravity", args={"55"}
    local full  = text:sub(2):lower():match("^%s*(.-)%s*$")
    local parts = {}
    for word in full:gmatch("%S+") do table.insert(parts, word) end
    local typed = parts[1] or ""
    local args  = {}
    for i = 2, #parts do table.insert(args, parts[i]) end

    local found = false
    for _, cmd in ipairs(COMMANDS) do
        local isMatch = cmd.name == typed
        if not isMatch and cmd.alias then
            for _, a in ipairs(cmd.alias) do
                if a == typed then isMatch = true; break end
            end
        end
        if isMatch then cmd.action(args); found = true; break end
    end
    if not found and firstSuggestCmd then
        firstSuggestCmd.action(args); found = true
    end
    if not found then
        cmdInput.TextColor3 = Color3.fromRGB(255, 80, 80)
        task.delay(0.5, function() cmdInput.TextColor3 = Color3.fromRGB(210, 210, 210) end)
    end

    closeBar()
end)

-- ══════════════════════════════════════════
--  KEYBINDS LISTENER
-- ══════════════════════════════════════════
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    local keyName = tostring(input.KeyCode):gsub("Enum.KeyCode.","")
    for _, kb in ipairs(_G.keybinds) do
        if kb.key == keyName:upper() then
            -- find and run the command
            for _, cmd in ipairs(COMMANDS) do
                local isMatch = cmd.name == kb.cmd
                if not isMatch and cmd.alias then
                    for _, a in ipairs(cmd.alias) do if a == kb.cmd then isMatch = true break end end
                end
                if isMatch then pcall(cmd.action, {}); break end
            end
        end
    end
end)

-- ══════════════════════════════════════════
--  ' KEY → TOGGLE BAR
-- ══════════════════════════════════════════
UserInputService.InputBegan:Connect(function(input, _gp)
    if input.KeyCode == Enum.KeyCode.Quote then
        if isChatFocused() then return end
        if barOpen then closeBar() else openBar() end
        return
    end
    if input.KeyCode == Enum.KeyCode.Escape and barOpen then
        closeBar()
    end
end)

-- ══════════════════════════════════════════
--  CLICK OUTSIDE → CLOSE BAR
-- ══════════════════════════════════════════
UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
    if not barOpen then return end

    local mousePos = UserInputService:GetMouseLocation()
    local panelTotalH = togglesPanelOpen and 280 or 0
    local barBottom = INPUT_Y + INPUT_H + panelTotalH
    local clickedInsideY = mousePos.Y >= 0 and mousePos.Y <= barBottom

    if not clickedInsideY then
        closeBar()
        return
    end

    task.defer(function()
        local focused = UserInputService:GetFocusedTextBox()
        if focused == nil then
            cmdInput:CaptureFocus()
        end
    end)
end)
