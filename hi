                        target = p; break
                    end
                end
                local troot = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")
                local root  = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if troot and root then
                    rot = rot + speed
                    root.CFrame = CFrame.new(troot.Position)
                        * CFrame.Angles(0, math.rad(rot), 0)
                        * CFrame.new(distance, 0, 0)
                end
            end)
            _G.orbitFaceConn = RunService.RenderStepped:Connect(function()
                if not _G.orbitOn then _G.orbitFaceConn:Disconnect(); return end
                local target = nil
                for _, p in pairs(Players:GetPlayers()) do
