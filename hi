            if _G.fcKeyUp    then _G.fcKeyUp:Disconnect()    end
            if _G.fcRender   then _G.fcRender:Disconnect()   end
            _G.fcKeyDown = UserInputService.InputBegan:Connect(function(inp, gp)
                if not gp then keys[inp.KeyCode] = true end
            end)
            _G.fcKeyUp = UserInputService.InputEnded:Connect(function(inp)
                keys[inp.KeyCode] = nil
            end)
            local yaw, pitch = 0, 0
            local lastMouse  = UserInputService:GetMouseLocation()
            _G.fcRender = RunService.RenderStepped:Connect(function(dt)
                if not _G.freecamOn then return end
                local mouse = UserInputService:GetMouseLocation()
                local delta = mouse - lastMouse
                lastMouse   = mouse
                if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
                    yaw   = yaw   - delta.X * 0.3
                    pitch = math.clamp(pitch - delta.Y * 0.3, -80, 80)
                end
                local rot = CFrame.Angles(0, math.rad(yaw), 0) * CFrame.Angles(math.rad(pitch), 0, 0)
                local spd = moveSpeed * (keys[Enum.KeyCode.LeftShift] and 3 or 1)
                local move = Vector3.new(
                    (keys[Enum.KeyCode.D] and 1 or 0) - (keys[Enum.KeyCode.A] and 1 or 0),
                    (keys[Enum.KeyCode.E] and 1 or 0) - (keys[Enum.KeyCode.Q] and 1 or 0),
                    (keys[Enum.KeyCode.S] and 1 or 0) - (keys[Enum.KeyCode.W] and 1 or 0)
                )
                camPos = camPos * CFrame.new(move * spd * 60 * dt)
                cam.CFrame = CFrame.new(camPos.Position) * rot
            end)
            _G.fcOldCamType = oldType
        end,
    },
