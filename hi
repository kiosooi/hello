local function showSuggestions(query)
    clearSuggestions()
    -- Each match is {cmd=cmd, matchedAlias=aliasOrNil}
    local matches = {}
    local seen    = {}
    for _, cmd in ipairs(COMMANDS) do
        if not seen[cmd] then
            local matchedAlias = nil
            -- check main name
            if cmd.name:sub(1, #query) == query:lower() then
                matchedAlias = nil  -- matched by main name
            elseif cmd.alias then
                -- check each alias
                for _, a in ipairs(cmd.alias) do
                    if a:sub(1, #query) == query:lower() then
                        matchedAlias = a
                        break
                    end
                end
            end
            if matchedAlias ~= nil or cmd.name:sub(1, #query) == query:lower() then
                seen[cmd] = true
                table.insert(matches, {cmd = cmd, matchedAlias = matchedAlias})
                if #matches >= MAX_SUGGESTIONS then break end
            end
        end
    end
    if #matches == 0 then return end

    for i, match in ipairs(matches) do
        local cmd         = match.cmd
        local matchedAlias = match.matchedAlias
        if i == 1 then firstSuggestCmd = cmd end

        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(1, 0, 0, ROW_H)
        btn.BackgroundColor3 = ROW_COLORS[i] or ROW_COLORS[#ROW_COLORS]
        btn.BorderSizePixel  = 0
        btn.Text             = ""
        btn.LayoutOrder      = i
        btn.ZIndex           = 12
        btn.Parent           = suggestFrame

        -- Main label always shows the real command name
        local lbl = Instance.new("TextLabel")
        lbl.Size              = UDim2.new(1, -12, 1, 0)
        lbl.Position          = UDim2.new(0, 12, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text              = ";" .. cmd.name .. (cmd.args and (" " .. cmd.args) or "")
        lbl.TextColor3        = Color3.fromRGB(210, 210, 210)
        lbl.Font              = Enum.Font.Code
        lbl.TextSize          = 16
        lbl.TextXAlignment    = Enum.TextXAlignment.Left
        lbl.ZIndex            = 13
        lbl.Parent            = btn

        -- If matched via alias, show a small tag on the right: "alias: fc"
        if matchedAlias then
            local aliasTag = Instance.new("TextLabel")
            aliasTag.Size              = UDim2.new(0, 120, 1, 0)
            aliasTag.Position          = UDim2.new(1, -124, 0, 0)
            aliasTag.BackgroundTransparency = 1
            aliasTag.Text              = "alias: ;" .. matchedAlias
            aliasTag.TextColor3        = Color3.fromRGB(255, 196, 0)
            aliasTag.Font              = Enum.Font.Code
            aliasTag.TextSize          = 12
            aliasTag.TextXAlignment    = Enum.TextXAlignment.Right
            aliasTag.ZIndex            = 13
            aliasTag.Parent            = btn
        end

        local dfBg = btn.BackgroundColor3
        btn.MouseEnter:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(100,100,100) end)
        btn.MouseLeave:Connect(function() btn.BackgroundColor3 = dfBg end)
        btn.MouseButton1Click:Connect(function()
            -- clicking always inserts the real command name
            cmdInput.Text = ";" .. cmd.name .. " "
            cmdInput.CursorPosition = #cmdInput.Text + 1
            clearSuggestions()
            cmdInput:CaptureFocus()
        end)
    end

    suggestFrame.Size    = UDim2.new(1, 0, 0, #matches * ROW_H)
    suggestFrame.Visible = true
end

-- Strip ' on open, show suggestions
cmdInput:GetPropertyChangedSignal("Text"):Connect(function()
    local t = cmdInput.Text
    if tick() - openedAt < 0.25 then
        local cleaned = t:gsub("'", "")
        if cleaned ~= t then
            cmdInput.Text = cleaned
            cmdInput.CursorPosition = #cleaned + 1
            return
        end
    end
    if t:sub(1,1) == ";" and #t > 1 then
        showSuggestions(t:sub(2):lower())
    else
        clearSuggestions()
    end
end)

